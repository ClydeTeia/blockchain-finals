# Blockchain finals verifier (deployer wallet - has ETH + VERIFIER_ROLE for on-chain KYC sync)
VERIFIER_PRIVATE_KEY=0x
# Blockchain finals validator (signs completion proofs)
VALIDATOR_PRIVATE_KEY=0x
SESSION_SECRET=random-64-string
DEPLOYER_PRIVATE_KEY=0x

# Currently not implemented
CAPTCHA_SECRET_KEY=cloudflare-turnstile-key

# Can support multiple admin wallets
ADMIN_WALLET_ALLOWLIST=0x,0x
NEXT_PUBLIC_ADMIN_WALLET_ALLOWLIST=0x,0x
NEXT_PUBLIC_CREATOR_WALLET_ALLOWLIST=0x

