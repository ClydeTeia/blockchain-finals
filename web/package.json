{
    "name": "@surveychain/web",
    "private": true,
    "version": "0.1.0",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "set ESLINT_USE_FLAT_CONFIG=false&& eslint . --max-warnings=0",
        "typecheck": "tsc --noEmit --incremental false -p tsconfig.typecheck.json",
        "test": "pnpm exec vitest run",
        "coverage": "pnpm exec vitest run --coverage",
        "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
        "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts"
    },
    "dependencies": {
        "drizzle-kit": "^0.31.10",
        "drizzle-orm": "^0.45.2",
        "ethers": "^6.16.0",
        "next": "^15.5.0",
        "pg": "^8.20.0",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "surveychain-rewards": "file:.."
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.1.0",
        "@types/node": "22.15.3",
        "@types/pg": "^8.20.0",
        "@types/react": "19.1.2",
        "@types/react-dom": "19.1.2",
        "@vitest/coverage-v8": "^2.1.8",
        "dotenv": "^17.4.2",
        "eslint": "9.25.1",
        "eslint-config-next": "^15.5.0",
        "typescript": "5.8.3",
        "vitest": "^2.1.8"
    }
}
